# OpenAI-compatible API key (Groq, OpenAI, 9Router, etc.)
API_KEY=your_api_key_here

# Base URL for the OpenAI-compatible endpoint
# 9Router (local): http://localhost:20128/v1
# Groq:            https://api.groq.com/openai/v1
# OpenAI:          https://api.openai.com/v1
# Local (Ollama):  http://localhost:11434/v1
BASE_URL=https://api.groq.com/openai/v1

# Model IDs (leave empty to use the defaults below)
# 9Router examples: cc/claude-sonnet-4-6, minimax/MiniMax-M2.7, gc/gemini-3-flash-preview
# Groq examples:    openai/gpt-oss-120b
# OpenAI examples:  gpt-4o, gpt-4o-mini
GENERATION_MODEL=openai/gpt-oss-120b
EXTRACTION_MODEL=openai/gpt-oss-120b

# LLM tuning (optional — defaults shown)
GENERATION_TEMPERATURE=0.7
GENERATION_MAX_TOKENS=2000
EXTRACTION_TEMPERATURE=0.1
EXTRACTION_MAX_TOKENS=1500
